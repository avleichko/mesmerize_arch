%% Mesmerize Content Evidence Platform — C4 Container (Mermaid)
%% Approach 1: coarse domain microservices, REST + SQS
%% Companion: 06-c4-containers.puml

C4Container
    title Mesmerize Content Evidence Platform — C4 Containers (REST + SQS)

    Person(clinician, "Clinician", "Launches SMART app from athenahealth")
    Person(admin, "Admin / Staff", "Command Center")
    Person_Ext(patient, "Patient", "Views device content (no login)")

    System_Ext(ehr, "athenahealth EHR", "SMART launch + FHIR R4")
    System_Ext(auth0, "Auth0", "Admin authentication")
    System_Ext(esper, "Esper MDM", "Device tokens / fleet")
    System_Ext(sanity, "Sanity CMS", "Editorial content")
    System_Ext(biodigital, "BioDigital", "3D models")
    System_Ext(mjh, "MJH / Pharmacy Times", "Articles")

    Container_Boundary(mesmerize, "Mesmerize Platform") {
        Container(smart_app, "SMART Web App", "React 19, fhirclient.js", "EHR iframe: recommend, pair, push, billing review. FHIR token stays in browser.")
        Container(device_apps, "Device PWA / Web Apps", "React 19, Vite", "Exam / Waiting / Command Center / Bridge")
        Container(gateway, "API Gateway / Edge", "CloudFront + ALB", "TLS + REST routing")

        Container(session_svc, "session-service", "NestJS / ECS", "Opaque sessions, ICD-10, device group, lifecycle")
        Container(content_svc, "content-service", "NestJS / ECS", "Catalog + ICD-10 recommend + CMS projection")
        Container(device_svc, "device-realtime-service", "NestJS, Socket.io / ECS", "Pairing, commands, WebSockets")
        Container(engagement_svc, "engagement-service", "NestJS / ECS", "De-identified engagement telemetry")
        Container(billing_svc, "billing-evidence-service", "NestJS / ECS", "Suggestions, approve, export")
        Container(org_svc, "org-identity-service", "NestJS / ECS", "Orgs, Auth0 JWT / RBAC")
        Container(audit_svc, "audit-telemetry-service", "NestJS worker / ECS", "Audit/diagnostic ingest (no PHI)")
        Container(ads_svc, "ads-service", "NestJS / ECS", "Ads / proof-of-play (optional clinical path)")

        ContainerDb(postgres, "PostgreSQL 16", "RDS", "De-identified data (schema/DB per service)")
        ContainerDb(redis, "Redis 7", "ElastiCache", "Presence, Socket.io adapter, cache")
        ContainerDb(s3, "Object Storage", "S3", "Media + ad assets")
        ContainerQueue(sqs, "Async backbone", "SQS + DLQs", "Commands, engagement, session, billing, audit")
    }

    Rel(clinician, ehr, "Opens chart")
    Rel(ehr, smart_app, "EHR launch iframe")
    Rel(smart_app, ehr, "FHIR R/W with EHR token")
    Rel(clinician, smart_app, "Uses")
    Rel(admin, device_apps, "Uses")
    Rel(patient, device_apps, "Views")

    Rel(smart_app, gateway, "HTTPS REST (Mesmerize session token)")
    Rel(device_apps, gateway, "HTTPS REST")
    Rel(device_apps, device_svc, "Socket.io")

    Rel(gateway, session_svc, "REST")
    Rel(gateway, content_svc, "REST")
    Rel(gateway, device_svc, "REST")
    Rel(gateway, engagement_svc, "REST")
    Rel(gateway, billing_svc, "REST")
    Rel(gateway, org_svc, "REST")
    Rel(gateway, ads_svc, "REST")

    Rel(session_svc, sqs, "session.* events")
    Rel(device_svc, sqs, "device.command.*")
    Rel(engagement_svc, sqs, "engagement.recorded")
    Rel(billing_svc, sqs, "session.ended → suggestions")
    Rel(audit_svc, sqs, "audit / diagnostic")
    Rel(content_svc, sqs, "CMS sync jobs")

    Rel(session_svc, postgres, "R/W")
    Rel(content_svc, postgres, "R/W")
    Rel(device_svc, postgres, "R/W")
    Rel(device_svc, redis, "R/W")
    Rel(engagement_svc, postgres, "R/W")
    Rel(billing_svc, postgres, "R/W")
    Rel(org_svc, postgres, "R/W")
    Rel(ads_svc, postgres, "R/W")
    Rel(content_svc, s3, "Media")
    Rel(ads_svc, s3, "Ads")

    Rel(org_svc, auth0, "OIDC / JWT")
    Rel(device_svc, esper, "Device identity")
    Rel(content_svc, sanity, "Sync")
    Rel(content_svc, biodigital, "Models")
    Rel(content_svc, mjh, "Articles")

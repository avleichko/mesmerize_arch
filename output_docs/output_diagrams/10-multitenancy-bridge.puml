@startuml mesmerize-multitenancy-bridge
title Mesmerize Multitenancy — Mode B: Bridge\nShared DB + tenantId column + isolated S3 folders\n(Default for SOW #3 / pilot)

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam roundCorner 8
skinparam defaultFontName Helvetica

rectangle "Domain services\n(NestJS microservices)" as SVC #B3D4FC
queue "SQS\n(tenantId + optional clinicId)" as SQS #B3D4FC
rectangle "Data access layer\nALWAYS filter by tenantId" as DATA #B3D4FC

database "Org config\ntenancyMode = bridge" as CFG #E8E8E8

frame "Bridge — Shared Aurora/Postgres" as BR {
  database "Shared DB" as DB #B3D4FC

  rectangle "organization\n• id : tenantId\n• name\n• tenancyMode" as ORG #E8F4FF

  rectangle "tenant-owned table\n(e.g. session, engagement)\n• id\n• tenantId (FK → organization)\n• clinicId\n• deviceGroupId\n• value / payload" as TBL #E8F4FF

  rectangle "clinic (sub-scope)\n• id : clinicId\n• tenantId\n• name" as CLINIC #E8F4FF

  ORG --> TBL : tenantId
  ORG --> CLINIC : tenantId
}

frame "Shared S3 bucket — folder isolation" as S3F {
  storage "s3://mesmerize-media/\n  {tenantId}/\n    {clinicId}/\n      content|exports|ads/..." as S3 #B3D4FC
}

SVC --> SQS
SQS --> DATA
SVC --> DATA
DATA --> CFG
DATA --> DB : WHERE tenantId = :tenantId\n(and clinicId when scoped)
DATA --> S3 : put/get under\n{tenantId}/{clinicId}/

note bottom of DATA
  Logical isolation via tenantId column.
  Fail closed: queries without tenantId are forbidden.
  S3 isolation via prefixes (not separate buckets required).
  Pilot default mode.
end note

@enduml
